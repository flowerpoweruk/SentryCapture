<Window x:Class="SentryCapture.Views.CameraEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera" Height="480" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI" ShowInTaskbar="False">

    <Border Style="{StaticResource Card}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderText" Text="Add Camera" FontSize="18" FontWeight="Bold" />

            <!-- Name -->
            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Text="Camera name" FontWeight="SemiBold" />
                <TextBlock Text="Used to build folder and file names (e.g. M6 J19 Northbound)."
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4" />
                <TextBox x:Name="NameBox" Padding="8,6" FontSize="13" />
            </StackPanel>

            <!-- URL -->
            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                <TextBlock Text="Image URL" FontWeight="SemiBold" />
                <TextBlock Text="The direct JPEG URL to poll every 30 seconds."
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4" />
                <TextBox x:Name="UrlBox" Padding="8,6" FontSize="13" />
            </StackPanel>

            <!-- Headers -->
            <StackPanel Grid.Row="3" Margin="0,14,0,0">
                <TextBlock Text="Custom headers (optional)" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4"
                           Text="One per line as &quot;Header: value&quot;. Use only if the feed rejects plain requests (e.g. Referer: https://site). A browser-like User-Agent is sent by default." />
            </StackPanel>
            <TextBox x:Name="HeadersBox" Grid.Row="4" Height="90" Padding="8,6" FontSize="12"
                     FontFamily="Consolas, Cascadia Mono, monospace"
                     AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,0,0" />

            <TextBlock x:Name="ErrorText" Grid.Row="5" Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,10,0,0" Visibility="Collapsed" />

            <!-- Buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel" Style="{StaticResource BaseButton}"
                        IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0" />
                <Button x:Name="SaveButton" Content="Save" Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
